<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0F0F1A"
        app:title="Terminal Remote"
        app:titleTextColor="#FFFFFF"
        app:menu="@menu/main_menu"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/statusIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/disconnected"
        android:textSize="12sp"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/toolbar"
        app:layout_constraintEnd_toEndOf="@id/toolbar"
        android:layout_marginEnd="8dp" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#16213E"
        app:tabMode="scrollable"
        app:tabTextColor="#AAAAAA"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#1E88E5"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <ScrollView
        android:id="@+id/terminalScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toTopOf="@id/specialKeysBar">

        <TextView
            android:id="@+id/terminalOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:textColor="#E0E0E0"
            android:background="#1A1A2E"
            android:gravity="top|start"
            android:textIsSelectable="true" />
    </ScrollView>

    <!-- Special Keys Bar -->
    <HorizontalScrollView
        android:id="@+id/specialKeysBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F0F1A"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/inputBar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEsc"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_margin="2dp"
                android:text="ESC"
                android:textSize="11sp"
                android:textColor="#CCCCCC"
                android:minWidth="48dp"
                app:strokeColor="#444444"
                app:cornerRadius="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTab"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_margin="2dp"
                android:text="TAB"
                android:textSize="11sp"
                android:textColor="#CCCCCC"
                android:minWidth="48dp"
                app:strokeColor="#444444"
                app:cornerRadius="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCtrl"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_margin="2dp"
                android:text="CTRL"
                android:textSize="11sp"
                android:textColor="#CCCCCC"
                android:minWidth="48dp"
                app:strokeColor="#444444"
                app:cornerRadius="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCtrlC"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_margin="2dp"
                android:text="C-c"
                android:textSize="11sp"
                android:textColor="#FF5555"
                android:minWidth="48dp"
                app:strokeColor="#444444"
                app:cornerRadius="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_margin="2dp"
                android:text="^"
                android:textSize="14sp"
                android:textColor="#CCCCCC"
                android:minWidth="42dp"
                app:strokeColor="#444444"
                app:cornerRadius="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDown"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_margin="2dp"
                android:text="v"
                android:textSize="14sp"
                android:textColor="#CCCCCC"
                android:minWidth="42dp"
                app:strokeColor="#444444"
                app:cornerRadius="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeft"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_margin="2dp"
                android:text="&lt;"
                android:textSize="14sp"
                android:textColor="#CCCCCC"
                android:minWidth="42dp"
                app:strokeColor="#444444"
                app:cornerRadius="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRight"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_margin="2dp"
                android:text="&gt;"
                android:textSize="14sp"
                android:textColor="#CCCCCC"
                android:minWidth="42dp"
                app:strokeColor="#444444"
                app:cornerRadius="4dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Input Bar -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0F0F1A"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/terminalInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="#16213E"
            android:textColor="#E0E0E0"
            android:textColorHint="#666666"
            android:hint="$ command..."
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:imeOptions="actionSend"
            android:inputType="text|textNoSuggestions" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
